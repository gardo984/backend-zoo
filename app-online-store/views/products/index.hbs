{{#> app}}
	{{#*inline "content"}}
		<div class="row">
			{{#each viewData.products }}
			<div class="col-md-4 col-log-3 mb-2">
				<div class="card">
					<img src="/uploads/{{getImage}}" class="card-img-top img-card">
					<div class="card-body text-center">
						<a href="/products/{{getId}}" class="btn bg-primary text-white">
							{{getName}}
						</a>
						<p class="card-text mt-2">
							<small class="text-muted">${{getPrice}}</small>
						</p>
						{{#unless isActive}}
							<span class="badge bg-secondary">Inactive</span>
						{{/unless}}
					</div>
				</div>
			</div>
			{{/each }}
		</div>
	{{/inline}}
{{/app}}
